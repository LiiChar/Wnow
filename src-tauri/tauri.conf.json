{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "wnow",
  "version": "0.1.0",
  "identifier": "com.litav.wnow",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "overlay",
        "title": "Wnow Translator",
        "url": "/",
        "width": 1280,
        "height": 720,
        "transparent": true,
        "decorations": false,
        "maximized": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": true,
        "focus": false,
        "acceptFirstMouse": true,
        "shadow": false,
        "resizable": false
      },
      {
        "label": "main",
        "title": "Wnow",
        "url": "/",
        "width": 364,
        "height": 530,
        "minWidth": 380,
        "minHeight": 500,
        "transparent": false,
        "decorations": false,
        "maximized": false,
        "alwaysOnTop": false,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/**/*"
    ]
  }
}
