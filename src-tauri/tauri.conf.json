{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "wnow",
  "version": "0.1.0",
  "identifier": "com.litav.wnow",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist",
    "removeUnusedCommands": true
  },
  "app": {
    "security": {
      "assetProtocol": {
        "scope": {
          "allow": ["**/resources/**"]
        },
        "enable": true
      },
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost blob: data:; media-src 'self' asset: http://asset.localhost blob:; script-src 'unsafe-inline' 'self' asset: http://asset.localhost blob:; style-src 'unsafe-inline' 'self' asset: http://asset.localhost blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/dictionary/**/*",
      "resources/fonts/**/*",
      "resources/ocr-model/**/*",
      "resources/screenshot"
    ]
  }
}
